{
  "name": "openai-oxide",
  "version": "0.9.5",
  "description": "Native Node.js bindings for openai-oxide powered by napi-rs.",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.d.ts",
    "index.js",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fortunto2/openai-oxide.git",
    "directory": "openai-oxide-node"
  },
  "homepage": "https://github.com/fortunto2/openai-oxide/tree/main/openai-oxide-node#readme",
  "bugs": {
    "url": "https://github.com/fortunto2/openai-oxide/issues"
  },
  "license": "MIT",
  "keywords": [
    "openai",
    "rust",
    "napi-rs",
    "node-addon",
    "bindings"
  ],
  "napi": {
    "binaryName": "openai-oxide",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "artifacts": "napi artifacts --output-dir artifacts --npm-dir npm",
    "bench": "node examples/bench_node.js",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "create:npm-dirs": "napi create-npm-dirs --npm-dir npm",
    "pack:preview": "pnpm pack --pack-destination .preview",
    "prepublishOnly": "napi prepublish -t npm --npm-dir npm",
    "test": "node test.js",
    "version": "napi version --npm-dir npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "openai": "^6.32.0"
  },
  "packageManager": "pnpm@10.8.1",
  "optionalDependencies": {
    "openai-oxide-darwin-x64": "0.9.5",
    "openai-oxide-darwin-arm64": "0.9.5",
    "openai-oxide-win32-x64-msvc": "0.9.5",
    "openai-oxide-linux-x64-gnu": "0.9.5",
    "openai-oxide-linux-x64-musl": "0.9.5",
    "openai-oxide-linux-arm64-gnu": "0.9.5",
    "openai-oxide-linux-arm64-musl": "0.9.5"
  }
}